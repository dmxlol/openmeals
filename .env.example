# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/openmeals

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Celery — RabbitMQ broker, Redis result backend
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Embeddings
# Options: sentence-transformers | triton | openai | mock
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# S3-compatible object storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
# Set for LocalStack or any S3-compatible endpoint; omit for real AWS
# AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=openmeals
S3_CDN_BASE_URL=https://cdn.example.com

# CORS — comma-separated list of allowed origins (leave empty to allow all, dev only)
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Branded API clients — one env var per brand, value is the client's PEM public key
# CLIENTS__OPENPEEL=-----BEGIN PUBLIC KEY-----\n...
